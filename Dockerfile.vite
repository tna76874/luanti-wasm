FROM node:20-slim

WORKDIR /app

# Copy nur package files
COPY custom_frontend/package.json ./

# Install dependencies (erzeugt auch package-lock.json)
RUN npm install --no-progress

# Copy source
COPY custom_frontend/src ./src

# Default: www wird zur runtime gemountet
ENV RELEASE_UUID=dev

ENTRYPOINT ["npm", "run", "build"]
